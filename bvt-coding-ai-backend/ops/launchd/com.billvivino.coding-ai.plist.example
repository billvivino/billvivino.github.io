<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.billvivino.coding-ai</string>

    <key>WorkingDirectory</key>
    <string>/Users/billvivino/Documents/GitHub/billvivino.github.io/bvt-coding-ai-backend</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/billvivino/Documents/GitHub/billvivino.github.io/bvt-coding-ai-backend/.venv/bin/uvicorn</string>
      <string>app.main:app</string>
      <string>--host</string>
      <string>127.0.0.1</string>
      <string>--port</string>
      <string>8787</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/billvivino/Documents/GitHub/billvivino.github.io/bvt-coding-ai-backend/logs/api.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/billvivino/Documents/GitHub/billvivino.github.io/bvt-coding-ai-backend/logs/api.err.log</string>
  </dict>
</plist>
