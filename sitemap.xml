---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign base = site.url | append: site.baseurl %}

  {% for page in site.pages %}
    {% assign skip_sitemap_page = false %}
    {% if page.noindex == true
       or page.url == "/sitemap.xml"
       or page.url == "/assets/css/style.css"
       or page.url contains "/_layouts/"
       or page.url contains "/_includes/" %}
      {% assign skip_sitemap_page = true %}
    {% endif %}

    {% unless skip_sitemap_page %}
      <url>
        <loc>{{ base }}{{ page.url }}</loc>
        {% if page.last_modified_at %}
          <lastmod>{{ page.last_modified_at | date: "%Y-%m-%d" }}</lastmod>
        {% endif %}
      </url>
    {% endunless %}
  {% endfor %}

  {% for post in site.posts %}
      <url>
        <loc>{{ base }}{{ post.url }}</loc>
        <lastmod>{{ post.date | date: "%Y-%m-%d" }}</lastmod>
      </url>
  {% endfor %}
</urlset>
